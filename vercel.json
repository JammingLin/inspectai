{
  "version": 2,
  "regions": ["hkg1"],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/export-pdf.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/app.html", "destination": "/app.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
